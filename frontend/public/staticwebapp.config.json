{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "/brand/*", "*.{css,js,map,ico,png,svg,jpg,jpeg,webp,woff,woff2}"]
  },
  "mimeTypes": {
    ".json": "application/json"
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  }
}
