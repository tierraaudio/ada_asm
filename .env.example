# =========================================
# ADA ASM — local development environment
# Copy this file to `.env` and fill in / override values.
# =========================================

# ---- Runtime -----------------------------
ENV=development
LOG_LEVEL=INFO

# ---- PostgreSQL --------------------------
POSTGRES_USER=ada_asm
POSTGRES_PASSWORD=ada_asm
POSTGRES_DB=ada_asm
POSTGRES_PORT=5432

# ---- Redis -------------------------------
REDIS_PORT=6379

# ---- Service ports -----------------------
BACKEND_PORT=8000
FRONTEND_PORT=5173

# ---- Backend connection strings ----------
# The runtime app uses the async driver (asyncpg). Alembic's env.py rewrites
# this to the sync driver (psycopg) when applying migrations.
DATABASE_URL=postgresql+asyncpg://ada_asm:ada_asm@postgres:5432/ada_asm
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ---- Auth (JWT) --------------------------
# Generate a secure value for any non-local environment:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-in-env
# Token TTLs. Access tokens are short-lived (15 min by default); refresh tokens
# survive longer (14 days). Password-reset tokens expire in 1 hour.
JWT_ACCESS_TOKEN_TTL_SECONDS=900
JWT_REFRESH_TOKEN_TTL_SECONDS=1209600
PASSWORD_RESET_TOKEN_TTL_SECONDS=3600

# ---- Rate limiting -----------------------
# Per-IP request budget for /auth/login and /auth/password-recovery.
LOGIN_RATE_LIMIT_PER_MINUTE=10

# ---- Password policy ---------------------
PASSWORD_MIN_LENGTH=12
PASSWORD_MAX_LENGTH=128

# ---- Frontend base URL -------------------
# Used to build password-reset links sent by email.
FRONTEND_BASE_URL=http://localhost:5173

# ---- SMTP (optional) ---------------------
# When SMTP_HOST is empty, the backend uses ConsoleEmailSender (logs only).
# When set, configure the rest and emails are dispatched via aiosmtplib.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# ---- CORS --------------------------------
# Comma-separated list of allowed origins. Include both localhost and the
# *.local LAN hostname so the frontend reaches the backend from other devices
# on the same network during local testing.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://*.local:5173

# ---- Frontend build args -----------------
# Base URL of the backend. Do NOT include "/api/v1" — feature code appends it.
VITE_API_URL=http://localhost:8000
VITE_ENV=development

# ---- Supplier sync (change `supplier-sync`) ----
# Five-supplier integration. Each adapter ships disabled until BOTH (a) its
# credentials are present AND (b) its code is listed in
# `SUPPLIER_SYNC_ENABLED_SUPPLIERS`. Leave keys empty to skip that supplier.

# Mouser — https://www.mouser.com/api-hub/ → fill the access form (provides
# your egress public IP), API key arrives by email same day. Free.
MOUSER_API_KEY=

# DigiKey — https://developer.digikey.com/ → register an App, activate
# "Product Information V4", get Client ID + Client Secret. Sandbox first,
# then promote to Production. 1000 req/day on the standard tier.
DIGIKEY_CLIENT_ID=
DIGIKEY_CLIENT_SECRET=
DIGIKEY_OAUTH_TOKEN_URL=https://api.digikey.com/v1/oauth2/token

# TME — https://developers.tme.eu/en/signup (needs an existing tme.eu
# customer account). Get private token + app secret. Note: TME's `Symbol`
# field is its OWN SKU; the MPN lives in `OriginalSymbol`.
TME_TOKEN=
TME_APP_SECRET=

# Farnell / element14 — https://partner.element14.com/ → register and
# request an API key. Free with courtesy allowance.
FARNELL_API_KEY=
FARNELL_STORE_ID=es.farnell.com

# RS Online — not self-serve. Email RS commercial to request an App ID.
RS_API_KEY=

# Sync feature flags. Comma-separated. RS excluded by default.
SUPPLIER_SYNC_ENABLED_SUPPLIERS=mouser,digikey,tme,farnell
SUPPLIER_LOOKUP_PRIORITY=mouser,digikey,tme,farnell,rs
SUPPLIER_LOOKUP_CACHE_TTL_SECONDS=900
SUPPLIER_SYNC_DAILY_HOUR_UTC=3
